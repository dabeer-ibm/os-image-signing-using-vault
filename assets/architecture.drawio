      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="HCP Packer + Vault + Terraform → EC2" style="text;html=1;align=center;fontSize=20;fontStyle=1;fontColor=#1A1A1A" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1520" height="30" as="geometry" />
